<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\Pfad\Zu\Deiner\python.exe|C:\Pfad\Zu\Deiner\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>
  <appSettings>
    <add key="PYTHONPATH" value="C:\Users\cwhosting\Documents\web\m-sound" />
    <add key="WSGI_HANDLER" value="app.app" /> </appSettings>
</configuration>
